{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(uv run python -m pytest *)",
      "Bash(uv lock)",
      "Bash(uv sync *)",
      "Bash(ruff *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "auto",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/guard_scope.py"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/guard_bash.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/auto_format.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/action_log.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/enforce_eval.py"
          },
          {
            "type": "command",
            "command": "uv run python .claude/hooks/spec_gate.py"
          },
          {
            "type": "command",
            "command": "uv run python .claude/hooks/codex_gate.py"
          },
          {
            "type": "command",
            "command": "uv run python .claude/hooks/quality_gate.py"
          },
          {
            "type": "command",
            "command": "uv run python .claude/hooks/notify.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/checkpoint_before_compact.py",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/reinject_after_compact.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/agent_log.py"
          }
        ]
      }
    ]
  }
}
