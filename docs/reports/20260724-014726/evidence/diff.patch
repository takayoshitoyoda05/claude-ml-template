+        # ログ失敗で作業は止めないが、欠落を可視化する(Codex指摘の採用)
+        print(f"[agent_log] failed to write log: {e}", file=sys.stderr)
+
+    prune_old_logs(log_dir)
+
+    sys.exit(0)
+
+
+if __name__ == "__main__":
+    main()
