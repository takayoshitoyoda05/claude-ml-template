+        if key in payload:
+            entry[key] = payload[key]
+
+    log_file = (
+        log_dir / f"{datetime.now(timezone.utc).strftime('%Y%m%d')}-{session}.jsonl"
+    )
+    try:
+        with open(log_file, "a", encoding="utf-8") as f:
+            f.write(json.dumps(entry, ensure_ascii=False) + "\n")
