name: Spec Gate

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  spec-gate:
    runs-on: ubuntu-latest
    # CLAUDE_WORK_SCOPE 運用(設計書が projects/<name>/docs/active にある)では、
    # 下の env で検査対象を明示すること。未設定だと CI はリポジトリ直下の
    # docs/active しか見ず、そこに設計書が無ければ何も検査せずに通る。
    # env:
    #   CLAUDE_SPEC_DOCS: projects/<name>/docs/active
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v3

      - name: Run spec_gate (CI mode)
        run: |
          if [ -f ".claude/hooks/spec_gate.py" ]; then
            uv run python .claude/hooks/spec_gate.py --ci
          else
            echo "SKIP: .claude/hooks/spec_gate.py が未配置のためスキップします"
          fi
